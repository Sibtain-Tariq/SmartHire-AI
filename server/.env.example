# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/smarthire

# Firebase
FIREBASE_CREDENTIALS_PATH=./secrets/firebase-service-account.json

# Chroma
CHROMA_DB_DIR=./chroma_db

# Groq
